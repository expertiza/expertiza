<%= form_tag(:controller => "sign_up_sheet", :action => "assign_mentor_to_topic_action",:topic_id => params[:topic_id], :assignment_id => params[:assignment_id]) do %>
  <%= label_tag(:username, "Add Mentor to this topic:") %>
  <%= text_field_tag(:username) %>
  <%= hidden_field_tag "topic_id", params[:topic_id] %>
  <%= hidden_field_tag "assignment_id", params[:assignment_id] %>
  <%= submit_tag("Submit") %>
<% end %>