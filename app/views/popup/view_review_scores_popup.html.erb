<h2> Review by <%= Participant.find(@reviewer_id).fullname(@ip) %> </h2>
<% keys = @review_final_versions.keys %>
<% keys.each do |key| %>    
    <h4><b> Course    :</b> <%= Assignment.find(@assignment_id).course.name %></h4>
    <h4><b> Assignment:</b> <%= Assignment.find(@assignment_id).name %></h4>
    <% roundtitle = key.to_s %>
    <h4><b><%= roundtitle.titlecase %></b></h4>

    <table class="general" border="1">
      <% questionnaire_id = Questionnaire.find(@review_final_versions[key][:questionnaire_id]) %>
      <% questions = Question.where(questionnaire_id: questionnaire_id) %>
      <% num_responses = @review_final_versions[key][:response_ids].length %>
      <% responses = @review_final_versions[key][:response_ids] %>
      
      <!--      set column length equal for all responses-->
      <% item_width  = 100/(num_responses+1) %>
      
      <!-- show the team which did the review -->
      <!-- First Row -->
      <tr>
        <th colspan="3" style="background-color:#DDDDBB" width="<%= item_width %>%" > <b>ITEM</b></th>
        <% responses.each do |response_id| %>  
          <td width="<%= item_width %>%">
          <% team = Team.find(ResponseMap.find(Response.find(response_id).map_id).reviewee_id) %>
          <b><%= team.name %></b> <div style ="font-size:11px"> done at -- <%= Response.find(response_id).updated_at.strftime("%a, %b %d, %Y %I:%M:%S %p") %> &nbsp&nbsp</div>
          </td>
        <% end %>
      </tr>

      <!-- Questions and Responses Row -->
      <% questions.each do |question| %>
        <% unless question.is_a?(QuestionnaireHeader) && num_responses > 0 %>
          <tr>
            <th colspan="3" style="background-color:#DDDDBB" width="<%= item_width %>%" > <%= question.txt %></th>
            <!-- Show review summary of checkbox question -->
            <% if question.instance_of? Checkbox %>
              
              <% responses.each do |response_id| %>  
                <td align="center" width="<%= item_width %>%">
                  <% answer = Answer.where(response_id: response_id, question_id: question.id).first %>
                  <% unless answer.nil? %>
                    <%= answer.answer == 0 ? image_tag("delete_icon.png") : image_tag("Check-icon.png") %>
                  <% end %>
                </td>
              <% end %>

            <!-- Show review summary of a non checkbox question -->  
            <% else %>
            
              <% responses.each do |response_id| %>  
                <td width="<%= item_width %>%">
                  <% answer = Answer.where(response_id: response_id, question_id: question.id).first %>
                  <% unless answer.nil? %>
                  <div>
                    <div class="c<%= answer.answer %> grade-circle" ><p><%= answer.answer %></p></div>
                    <div><p><%= answer.comments.html_safe unless answer.comments.nil? %></p></div>
                  </div>
          <!--          <div class="c<%= answer.answer %> reviewscore" ><p><%= answer.answer %></p></div> 
                    <div class=reviewcomment ><p><%= answer.comments.html_safe unless answer.comments.nil? %></p></div> -->
                  <% end %>
                </td>
              <% end %>
              
            <% end %>
          </tr>
        
        <% else %>
          <% next %>
        
        <% end %>
      <% end %>  

      <!-- Row additional Comments -->
      <tr>
        <th colspan="3" style="background-color:#DDDDBB" width="<%= item_width %>%" > <b>Additional Comments</b></th>
        <% responses.each do |response_id| %>  
          <td width="<%= item_width %>%">
          <% team = Team.find(ResponseMap.find(Response.find(response_id).map_id).reviewee_id) %>
          <%=sanitize Response.find(response_id).additional_comment %>
          </td>
        <% end %>
      </tr>   
      
      <!-- Row LLM Evaluation Report -->
      <tr>
        <th colspan="3" style="background-color:#DDDDBB" width="<%= item_width %>%" > <b>LLM Evaluation Report</b></th>
        <% responses.each do |response_id| %>
          <% llm_status = @llm_evaluation_data[response_id] || {} %>
          <td width="<%= item_width %>%" style="padding: 5px;">
            <div>
              <div><strong>Status:</strong> <span class="badge <%= llm_status[:badge_class] %>"><%= llm_status[:status_text] %></span></div>
              <% if llm_status[:total_score].present? %>
                <div style="margin-top: 5px;"><strong>Total Score:</strong> <%= llm_status[:total_score] %></div>
              <% elsif llm_status[:score].present? %>
                <div style="margin-top: 5px;"><strong>Score:</strong> <%= llm_status[:score] %></div>
              <% end %>
              <% if llm_status[:rubric_breakdown].present? && llm_status[:rubric_breakdown].is_a?(Hash) %>
                <div style="margin-top: 5px; max-height: 300px; overflow-y: auto;">
                  <table border="1" style="width: 100%; font-size: 9px; border-collapse: collapse; table-layout: fixed;">
                    <thead>
                      <tr style="background-color: #f0f0f0; position: sticky; top: 0;">
                        <th style="padding: 2px; text-align: left; width: 20%; word-wrap: break-word;">Rubric</th>
                        <th style="padding: 2px; text-align: center; width: 10%;">Points</th>
                        <th style="padding: 2px; text-align: left; width: 35%; word-wrap: break-word;">Reason</th>
                        <th style="padding: 2px; text-align: left; width: 35%; word-wrap: break-word;">Explanation</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% llm_status[:rubric_breakdown].each do |rubric_name, rubric_info| %>
                        <% next unless rubric_info.is_a?(Hash) %>
                        <tr>
                          <td style="padding: 2px; vertical-align: top; word-wrap: break-word; font-size: 8px;"><%= rubric_name.to_s.humanize %></td>
                          <td style="padding: 2px; text-align: center; vertical-align: top;">
                            <%= rubric_info['score'].is_a?(Numeric) ? rubric_info['score'] : rubric_info['score'].to_s %>
                          </td>
                          <td style="padding: 2px; vertical-align: top; font-size: 8px; word-wrap: break-word;">
                            <%= truncate(rubric_info['justification'].to_s, length: 800) %>
                          </td>
                          <td style="padding: 2px; vertical-align: top; font-size: 8px; word-wrap: break-word;">
                            <%= rubric_info['explanation'].present? ? truncate(rubric_info['explanation'].to_s, length: 800) : '-' %>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              <% end %>
              <% if llm_status[:feedback].present? %>
                <div style="font-size: 11px; margin-top: 3px;">
                  <strong>Feedback:</strong> <%= truncate(llm_status[:feedback], length: 800) %>
                </div>
              <% elsif llm_status[:error_message].present? %>
                <div style="font-size: 11px; margin-top: 3px; color: #666;">
                  <%= truncate(llm_status[:error_message], length: 80) %>
                </div>
              <% end %>
              <% if llm_status[:show_button] && llm_status[:button_class].present? %>
                <button type="button" 
                        class="btn btn-sm <%= llm_status[:button_class].to_s %> show-llm-modal" 
                        style="margin-top: 3px;"
                        data-response-id="<%= response_id %>"
                        data-raw-response="<%= escape_javascript(llm_status[:raw_response].to_json) %>">
                  <%= llm_status[:button_text] %>
                </button>
              <% end %>
            </div>
          </td>
        <% end %>
      </tr>


    </table>

<br>
<% end #loop for keys %>
<br>

<!-- Dialog for displaying LLM Response -->
<div id="llmResponseModal" style="display:none;">
  <pre id="llmResponseContent" style="max-height: 500px; overflow-y: auto; white-space: pre-wrap; word-wrap: break-word; background-color: #f5f5f5; padding: 15px; border: 1px solid #ddd; margin: 0;"></pre>
</div>

<script>
$(document).ready(function() {
  $('.show-llm-modal').on('click', function() {
    var responseId = $(this).data('response-id');
    var rawResponseJson = $(this).data('raw-response');
    
    // Parse and format JSON for display
    var contentElement = $('#llmResponseContent');
    try {
      var rawResponse = typeof rawResponseJson === 'string' ? JSON.parse(rawResponseJson) : rawResponseJson;
      var formattedJson = JSON.stringify(rawResponse, null, 2);
      contentElement.text(formattedJson);
    } catch (e) {
      contentElement.text('Error displaying response: ' + e.message + '\n\nRaw data: ' + rawResponseJson);
    }
    
    // Show jQuery UI dialog
    $('#llmResponseModal').dialog({
      title: 'LLM Evaluation Report - Response ID: ' + responseId,
      modal: true,
      width: 800,
      maxHeight: 600,
      resizable: true,
      draggable: true,
      buttons: {
        "Close": function() {
          $(this).dialog("close");
        }
      }
    });
  });
});
</script>
 
