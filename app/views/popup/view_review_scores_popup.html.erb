<!-- Dialog for displaying LLM Response -->
<div id="llmResponseModal" style="display:none;">
  <pre id="llmResponseContent" style="max-height: 500px; overflow-y: auto; white-space: pre-wrap; word-wrap: break-word; background-color: #f5f5f5; padding: 15px; border: 1px solid #ddd; margin: 0;"></pre>
</div>

<script>
$(document).ready(function() {
  // Handle Finalize Score button click
  $('.finalize-score-btn').on('click', function() {
    var $btn = $(this);
    var responseId = $btn.data('response-id');
    var mcpReviewId = $btn.data('mcp-review-id');
    var $table = $('#rubric-table-' + responseId);
    
    if (!mcpReviewId) {
      alert('Error: MCP Review ID not found');
      return;
    }
    
    // Collect rubric data from editable fields (score) and original justification from data attribute
    var rubricData = {};
    $table.find('tr[data-rubric]').each(function() {
      var $row = $(this);
      var rubricName = $row.data('rubric');
      var score = $row.find('.rubric-score-input').val();
      // Use original justification from data attribute, not from input field
      var justification = $row.data('justification') || '';
      
      rubricData[rubricName] = {
        score: score === 'N/A' ? 'N/A' : (isNaN(parseFloat(score)) ? null : parseFloat(score)),
        justification: justification
      };
    });
    
    // Get feedback from editable textarea
    var $feedbackTextarea = $table.closest('td').find('.feedback-input');
    var feedback = $feedbackTextarea.length ? $feedbackTextarea.val() : '';
    
    // Disable button and show loading state
    $btn.prop('disabled', true).text('Finalizing...');
    
    // Send AJAX request to finalize
    $.ajax({
      url: '<%= url_for(controller: "popup", action: "finalize_llm_evaluation") %>',
      method: 'POST',
      data: {
        response_id: responseId,
        mcp_review_id: mcpReviewId,
        rubric_data: rubricData,
        feedback: feedback
      },
      dataType: 'json',
      success: function(response) {
        if (response.success) {
          alert('Score finalized successfully!');
          // Reload the page to show updated status
          location.reload();
        } else {
          alert('Error: ' + (response.error || 'Failed to finalize score'));
          $btn.prop('disabled', false).text('Finalize Score');
        }
      },
      error: function(xhr, status, error) {
        var errorMsg = 'Failed to finalize score';
        try {
          var response = JSON.parse(xhr.responseText);
          errorMsg = response.error || errorMsg;
        } catch (e) {
          errorMsg = error || errorMsg;
        }
        alert('Error: ' + errorMsg);
        $btn.prop('disabled', false).text('Finalize Score');
      }
    });
  });
  
  // Update total score when points are edited
  $('.rubric-score-input').on('change blur', function() {
    var $table = $(this).closest('table');
    var $td = $table.closest('td');
    var total = 0;
    var hasValidScores = false;
    
    $table.find('.rubric-score-input').each(function() {
      var score = $(this).val();
      if (score && score !== 'N/A' && !isNaN(parseFloat(score))) {
        total += parseFloat(score);
        hasValidScores = true;
      }
    });
    
    if (hasValidScores) {
      // Find and update total score display using specific class selector
      var $totalScoreValue = $td.find('.total-score-value');
      if ($totalScoreValue.length) {
        // Update only the value, not the entire div
        $totalScoreValue.text(total);
      } else {
        // If total score div doesn't exist, find the status div and add total score after it
        var $statusDiv = $td.find('div').first();
        if ($statusDiv.length && $statusDiv.text().indexOf('Status:') !== -1) {
          // Insert total score after status div
          $statusDiv.after('<div class="total-score-display" style="margin-top: 5px;"><strong>Total Score:</strong> <span class="total-score-value">' + total + '</span></div>');
        }
      }
    }
  });
});
</script>
 
