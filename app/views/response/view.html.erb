<h1><%= @title %> for <%= @assignment.name %></h1>
<div style="float:right">
<%= link_to "Email the author", author_response_index_path(email: @participant.user.email,response: @response.id) %>
</div>

<% if @instructor_review_score %>
  <% summative_score = @instructor_review_score.score_for_summative %>
  <% formative_score = @instructor_review_score.score_for_formative %>
  <% formative_max = 5 %>
  <% summative_max = 2 %>
  <% total_max = formative_max + summative_max %>
  <% total_score = [summative_score, formative_score].compact.sum %>
  <div style="margin: 12px 0; padding: 12px 14px; border: 1px solid #cfd8dc; border-radius: 8px; background-color: #f8fbf9;">
    <div>
      <strong>Total:</strong>
      <span style="color: #2e8b57; font-weight: 700; font-size: 1.25em;">
        <%= total_score %> out of <%= total_max %>
      </span>
      <% if summative_score.present? || formative_score.present? %>
        <span>
          (<%= formative_score || 0 %> out of <%= formative_max %> for feedback, <%= summative_score || 0 %> out of <%= summative_max %> for accuracy)
        </span>
      <% end %>
      <button type="button"
              id="get-detailed-evaluation-button"
              class="btn btn-info btn-sm"
              data-url="<%= detailed_evaluation_response_index_path(id: @response.id) %>"
              style="margin-left: 10px;">
        Get detailed evaluation
      </button>
    </div>
    <% if @instructor_review_score.feedback_for_summative.present? || @instructor_review_score.feedback_for_formative.present? %>
      <div style="margin-top: 8px;">
        <strong>Feedback:</strong>
        <% if @instructor_review_score.feedback_for_formative.present? %>
          <span><%= sanitize(@instructor_review_score.feedback_for_formative) %></span>
        <% end %>
        <% if @instructor_review_score.feedback_for_formative.present? && @instructor_review_score.feedback_for_summative.present? %>
          <span> </span>
        <% end %>
        <% if @instructor_review_score.feedback_for_summative.present? %>
          <span><%= sanitize(@instructor_review_score.feedback_for_summative) %></span>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<div id="detailed-evaluation-overlay" class="response-detailed-evaluation-overlay" style="display: none;">
  <div class="response-detailed-evaluation-panel" role="dialog" aria-labelledby="detailedEvaluationTitle" aria-modal="true">
    <div class="response-detailed-evaluation-panel-header">
      <h4 id="detailedEvaluationTitle" class="response-detailed-evaluation-panel-title">Detailed evaluation</h4>
      <button type="button" id="close-detailed-evaluation" class="response-detailed-evaluation-close" aria-label="Close">
        &times;
      </button>
    </div>
    <div class="response-detailed-evaluation-panel-body">
      <div id="detailed-evaluation-loading" class="response-detailed-evaluation-state" style="display: none;">
        Loading detailed evaluation...
      </div>
      <div id="detailed-evaluation-error" class="response-detailed-evaluation-state response-detailed-evaluation-error" style="display: none;"></div>
      <div id="detailed-evaluation-content"></div>
    </div>
  </div>
</div>

<% if !(@map.instance_of? TeammateReviewResponseMap) && !(@map.instance_of? BookmarkRatingResponseMap) %>
  <% topic_id = SignedUpTeam.topic_id(@participant.parent_id, @participant.user_id) %>
  <%= render :partial => 'submitted_content/main', :locals => {:participant => @contributor.participants.first, :stage => @assignment.current_stage(topic_id)} %>
<% end %>

<!-- Added a checkbox to enable students to mark their review as a sample for others, by E2022 @SujalAhrodia -->
<input type="checkbox" id="sample_cbx" checked="false"/>
<label id="sample_cbx_lbl" for="sample_cbx">I agree to share my review as a sample for others</label>

<% @review_versions = @map.get_all_versions %>
<% unless @review_versions.empty? %>
    <% @review_versions.each do |response| %>
    	<%= response.display_as_html %>
        <br/>
    <% end %>
    <hr/>
<% end %>

<% file_url = nil %>
<%= @response.display_as_html(nil, nil, file_url) %>
<br/>

<!--Check whether there is a UploadFile question.-->
<%if @map.instance_of?(ReviewResponseMap)%>
  <% current_folder = DisplayOption.new %>
  <% current_folder.name = "~/" %>
  <% response_map_id = Response.find(params[:id]).response_map.id %>
  <% files = @participant.files(@participant.review_file_path(response_map_id).to_s + current_folder.name) %>
  <% session_participant = AssignmentParticipant.where(parent_id: @assignment.id, user_id: session[:user].id).first %>
  <% session_participants_team = AssignmentTeam.team(session_participant) %>
  <% @review_questions.each do |question| %>
    <% if question.instance_of? UploadFile %>
      <%= display_directory_tree(@participant, files, true).html_safe %>
    <% end %>
  <% end %>
<%end%>

<%= @map.show_feedback(@response) %>
<br/>
<a href="javascript:window.history.back()">Back</a>

<!-- Script to toggle visibility on selecting the checkbox, by E2022 @SujalAhrodia -->
<script>
  $(document).on("ready",function(e){

    //Show a pop up message on selecting/unselecting the checkbox, by E2022 @SujalAhrodia
    $("#sample_cbx").prop("checked", <%= !@response.visibility.nil? && (@response.visibility == "public" || @response.visibility == "published")%>);

    $("#sample_cbx").on("change",function(e){
      var _d = $(this);
      var check = _d.is(":checked") ? 1 : 0;
      var visibility = check?"public":"private";

      // Construct respective message to be displayed, by E2022 @SujalAhrodia

      var message = check ? "Your review may now " : "Your review may no longer ";

      message += "be available for other students to view. Are you sure?";

      if(!confirm(message)){
        _d.prop("checked",!check);
      }
      else{
        // Ajax call to update the value in db

        $.ajax({
        "url":"/response_toggle_permission/"+"<%= @response.id %>",
        "type":"POST",
        "data":{
          "visibility":visibility
        },
        "dataType":"json"
      });
      }
    });

    $("#get-detailed-evaluation-button").on("click", function() {
      var overlay = $("#detailed-evaluation-overlay");
      var loading = $("#detailed-evaluation-loading");
      var error = $("#detailed-evaluation-error");
      var content = $("#detailed-evaluation-content");
      var url = $(this).data("url");

      loading.show();
      error.hide().text("");
      content.empty();
      overlay.show();
      $("body").addClass("response-detailed-evaluation-open");

      $.ajax({
        url: url,
        type: "GET",
        dataType: "json"
      }).done(function(data) {
        loading.hide();
        var details = data.detailed_evaluation || {};
        var categories = data.categories || Object.keys(details);
        var html = "";

        categories.forEach(function(category) {
          var entry = details[category];
          if (!entry) { return; }

          var label = category.replace(/_/g, " ").replace(/\b\w/g, function(letter) {
            return letter.toUpperCase();
          });

          html += '<div class="response-detailed-evaluation-item">';
          html +=   '<div class="response-detailed-evaluation-item-header">';
          html +=     '<span class="response-detailed-evaluation-item-label">' + $("<div>").text(label).html() + '</span>';
          html +=     '<span class="response-detailed-evaluation-item-score">Score: ' + $("<div>").text(entry.score == null ? "" : entry.score).html() + '</span>';
          html +=   '</div>';
          html +=   '<div class="response-detailed-evaluation-item-reasoning">' + $("<div>").text(entry.justification_reasoning || "").html() + '</div>';
          html += '</div>';
        });

        if (html.length === 0) {
          html = '<div class="response-detailed-evaluation-state">No detailed evaluation data was returned.</div>';
        }

        content.html(html);
      }).fail(function(xhr) {
        loading.hide();
        var message = "Unable to load detailed evaluation.";
        if (xhr.responseJSON && xhr.responseJSON.error) {
          message = xhr.responseJSON.error;
        }
        error.text(message).show();
      });
    });

    function closeDetailedEvaluation() {
      $("#detailed-evaluation-overlay").hide();
      $("body").removeClass("response-detailed-evaluation-open");
    }

    $("#close-detailed-evaluation").on("click", function() {
      closeDetailedEvaluation();
    });

    $("#detailed-evaluation-overlay").on("click", function(e) {
      if (e.target === this) {
        closeDetailedEvaluation();
      }
    });

    $(document).on("keydown", function(e) {
      if (e.key === "Escape") {
        closeDetailedEvaluation();
      }
    });
  });
</script>
