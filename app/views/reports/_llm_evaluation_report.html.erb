<div class='reviewreport'>
  <% if @assignment.is_sent_to_llm_for_processing %>
    <div class="alert alert-info">
      <p><strong>Assignment is already sent to LLM for processing. Resend to LLM for reprocessing.</strong></p>
      <%= button_to 'Resend to LLM', { controller: 'reports', action: 'send_to_llm', id: @assignment.id }, method: :post, class: 'btn btn-primary' %>
    </div>
  <% else %>
    <div class="alert alert-warning">
      <p>This assignment has not been sent to LLM for processing yet.</p>
      <%= button_to 'Send for Processing', { controller: 'reports', action: 'send_to_llm', id: @assignment.id }, method: :post, class: 'btn btn-success' %>
    </div>
  <% end %>
</div>
